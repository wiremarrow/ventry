    "strict": true,
    "contexts": [
      "Documentation Check",
      "Lint and Type Check",
      "Unit Tests (18)",
      "Unit Tests (20)",
      "PostgreSQL Integration Tests",
      "E2E Tests - chromium (1)",
      "E2E Tests - chromium (2)",
      "E2E Tests - firefox (1)",
      "E2E Tests - firefox (2)",
      "E2E Tests - webkit (1)",
      "E2E Tests - webkit (2)",
      "Build",
      "Coverage Gate"
