# Development Database Configuration - PostgreSQL
DATABASE_URL="postgresql://ventry:ventry_dev_password@localhost:5432/ventry_dev?schema=public"

# Redis Configuration (optional for dev)
REDIS_URL="redis://localhost:6379"

# Application Configuration
NODE_ENV="development"
PORT="3000"
FRONTEND_URL="http://localhost:3001"

# JWT Configuration
JWT_SECRET="dev-jwt-secret-change-in-production"
JWT_EXPIRATION="7d"
JWT_REFRESH_EXPIRATION="30d"

# AI Provider Configuration
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
AI_PROVIDER="openai"

# Email Configuration (use console in dev)
EMAIL_PROVIDER="console"

# Monitoring and Logging
LOG_LEVEL="debug"
SENTRY_DSN=""

# Feature Flags
ENABLE_AI_AGENTS="true"
ENABLE_REAL_TIME="true"
ENABLE_ANALYTICS="true"

# Security
CORS_ORIGINS="http://localhost:3001,http://localhost:3000"
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="1000"