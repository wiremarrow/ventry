# Ventry Production Environment Configuration
# Copy this file to .env.production and fill in the values
# NEVER commit the actual .env.production file

# ====================
# CORE CONFIGURATION
# ====================
NODE_ENV=production
APP_VERSION=${COMMIT_SHA}
APP_NAME=ventry
DEPLOYMENT_ENV=production

# ====================
# SECURITY
# ====================
# Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Generate with: openssl rand -base64 32
COOKIE_SECRET=
COOKIE_SECURE=true
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=strict
COOKIE_DOMAIN=.ventry.com

# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
ENCRYPTION_ALGORITHM=aes-256-gcm

# CORS Configuration
ALLOWED_ORIGINS=https://app.ventry.com,https://www.ventry.com
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,X-Organization-Id,X-Request-Id

# ====================
# DATABASE
# ====================
# PostgreSQL connection with SSL
DATABASE_URL=postgresql://ventry_prod:${DB_PASSWORD}@${DB_HOST}:5432/ventry_production?sslmode=require&connection_limit=10&pool_timeout=30

# Connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_POOL_ACQUIRE_TIMEOUT=60000
DATABASE_STATEMENT_TIMEOUT=30000

# Read replica for analytics (optional)
DATABASE_REPLICA_URL=postgresql://ventry_read:${DB_READ_PASSWORD}@${DB_READ_HOST}:5432/ventry_production?sslmode=require

# ====================
# REDIS
# ====================
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:6379
REDIS_CLUSTER_MODE=true
REDIS_KEY_PREFIX=ventry:prod:
REDIS_TTL_DEFAULT=3600
REDIS_CONNECTION_TIMEOUT=5000
REDIS_COMMAND_TIMEOUT=5000
REDIS_RETRY_STRATEGY=exponential
REDIS_MAX_RETRIES=3

# ====================
# API CONFIGURATION
# ====================
API_PORT=3000
API_HOST=0.0.0.0
API_BASE_URL=https://api.ventry.com
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW=60000
API_TIMEOUT=30000
API_BODY_LIMIT=10485760
API_TRUST_PROXY=true

# Rate limiting by tier
RATE_LIMIT_FREE_TIER=100
RATE_LIMIT_PRO_TIER=1000
RATE_LIMIT_ENTERPRISE_TIER=10000

# ====================
# AUTHENTICATION
# ====================
AUTH_SESSION_DURATION=86400000
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_DURATION=900000
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_REQUIRE_UPPERCASE=true
AUTH_PASSWORD_REQUIRE_LOWERCASE=true
AUTH_PASSWORD_REQUIRE_NUMBER=true
AUTH_PASSWORD_REQUIRE_SPECIAL=true
AUTH_MFA_ENABLED=true
AUTH_MFA_ISSUER=Ventry

# ====================
# MONITORING & LOGGING
# ====================
# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_ATTACH_STACKTRACE=true
SENTRY_AUTO_SESSION_TRACKING=true
SENTRY_SEND_DEFAULT_PII=false

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_TIMESTAMP=true
LOG_PRETTY=false
LOG_CORRELATION_ID=true
LOG_SANITIZE_SENSITIVE=true

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.ventry.com:4318
OTEL_SERVICE_NAME=ventry-backend
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# ====================
# AWS CONFIGURATION
# ====================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 for file storage
S3_BUCKET_NAME=ventry-production
S3_BUCKET_REGION=us-east-1
S3_UPLOAD_TIMEOUT=300000
S3_SIGNED_URL_EXPIRES=3600

# SES for emails
SES_FROM_EMAIL=noreply@ventry.com
SES_REPLY_TO_EMAIL=support@ventry.com

# ====================
# EXTERNAL SERVICES
# ====================
# SendGrid (alternative to SES)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@ventry.com
SENDGRID_TEMPLATE_WELCOME=
SENDGRID_TEMPLATE_RESET_PASSWORD=
SENDGRID_TEMPLATE_INVITE=

# Stripe (if payments enabled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Twilio (for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ====================
# FEATURE FLAGS
# ====================
ENABLE_SIGNUP=true
ENABLE_SOCIAL_AUTH=false
ENABLE_API_KEYS=true
ENABLE_WEBHOOKS=true
ENABLE_EXPORT=true
ENABLE_IMPORT=true
ENABLE_ANALYTICS=true
ENABLE_AI_FEATURES=false
ENABLE_MAINTENANCE_MODE=false
MAINTENANCE_MODE_MESSAGE=
MAINTENANCE_MODE_ALLOWED_IPS=

# ====================
# PERFORMANCE
# ====================
# Worker configuration
WORKER_THREADS=4
WORKER_MEMORY_LIMIT=512
UV_THREADPOOL_SIZE=16

# Cache configuration
CACHE_ENABLED=true
CACHE_TTL_USER_SESSION=3600
CACHE_TTL_ORGANIZATION=7200
CACHE_TTL_INVENTORY=300
CACHE_TTL_REPORTS=1800

# ====================
# BACKUP & RECOVERY
# ====================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=ventry-backups
BACKUP_ENCRYPTION_KEY=

# ====================
# COMPLIANCE
# ====================
GDPR_ENABLED=true
GDPR_DATA_RETENTION_DAYS=2555
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555
PII_ENCRYPTION_ENABLED=true

# ====================
# THIRD PARTY INTEGRATIONS
# ====================
# Webhooks
WEBHOOK_TIMEOUT=10000
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=1000
WEBHOOK_SIGNATURE_ALGORITHM=sha256

# Analytics
GOOGLE_ANALYTICS_ID=
MIXPANEL_TOKEN=
AMPLITUDE_API_KEY=

# ====================
# DEVELOPMENT/DEBUG
# ====================
# Set these to false in production
DEBUG_MODE=false
DEBUG_SQL_QUERIES=false
DEBUG_PERFORMANCE=false
ENABLE_SWAGGER_UI=false
ENABLE_GRAPHQL_PLAYGROUND=false

# ====================
# LOAD BALANCER
# ====================
LOAD_BALANCER_HEALTH_CHECK_PATH=/health
LOAD_BALANCER_HEALTH_CHECK_INTERVAL=30
LOAD_BALANCER_STICKY_SESSIONS=true

# ====================
# DEPLOYMENT
# ====================
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_ZONE=us-east-1a
BLUE_GREEN_ENABLED=true
CANARY_PERCENTAGE=10
ROLLBACK_ON_ERROR_THRESHOLD=5