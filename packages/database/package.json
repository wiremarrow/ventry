{
  "name": "@ventry/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:push": "dotenv -e ../../.env -- prisma db push --accept-data-loss",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:seed:basic": "dotenv -e ../../.env -- tsx prisma/seed.ts --basic",
    "db:seed:comprehensive": "dotenv -e ../../.env -- tsx prisma/seed.ts --comprehensive",
    "db:seed:multi-org": "dotenv -e ../../.env -- tsx prisma/seed-multi-org.ts",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.0.10",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.11.1",
    "ts-node": "^10.9.1",
    "tsx": "^4.19.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}