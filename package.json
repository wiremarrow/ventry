{
  "name": "ventry",
  "version": "0.0.0",
  "private": true,
  "description": "AI-Native Inventory Management System",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:integration": "turbo test:integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "db:push": "turbo db:push",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "prepare": "husky install",
    "playwright:install": "playwright install --with-deps",
    "ci:setup": "./tools/scripts/setup-github-repo.sh && ./tools/scripts/setup-ci-secrets.sh",
    "ci:validate": "./tools/scripts/validate-ci-setup.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@sentry/nextjs": "^7.91.0",
    "@sentry/node": "^7.91.0",
    "@types/node": "^24.0.10",
    "eslint": "^9.30.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "playwright": "^1.40.0",
    "prettier": "^3.1.0",
    "turbo": "^1.11.0",
    "typescript": "^5.3.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@8.10.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}