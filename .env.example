# Database Configuration
DATABASE_URL="postgresql://ventry:ventry_dev_password@localhost:5432/ventry_dev?schema=public"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# Application Configuration
NODE_ENV="development"
PORT="6060"
FRONTEND_URL="http://localhost:6061"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="7d"
JWT_REFRESH_EXPIRATION="30d"

# AI Provider Configuration
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
AI_PROVIDER="openai" # or "anthropic"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"
SMTP_FROM="Ventry <noreply@ventry.com>"

# Monitoring and Logging
LOG_LEVEL="debug" # debug, info, warn, error
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Feature Flags
ENABLE_AI_AGENTS="true"
ENABLE_REAL_TIME="true"
ENABLE_ANALYTICS="true"

# Security
CORS_ORIGINS="http://localhost:6061,http://localhost:6060"
RATE_LIMIT_WINDOW_MS="900000" # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"

# Storage (for future use)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET_NAME=""