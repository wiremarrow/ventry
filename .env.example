# Ventry Environment Configuration
# Copy this file to .env.local in the appropriate directory

# ====================================
# DATABASE CONFIGURATION
# ====================================

# PostgreSQL Database URL
# For local development with Docker
DATABASE_URL=postgresql://ventry:ventry_dev_password@localhost:5487/ventry_dev

# For Supabase (Phase 2 - Optional)
# Get these from your Supabase project dashboard: https://app.supabase.com
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ====================================
# SUPABASE CONFIGURATION (Phase 2)
# ====================================

# Supabase Project URL and Keys
# Found in Settings > API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-safe-to-expose
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-keep-secret

# ====================================
# AUTHENTICATION
# ====================================

# JWT Secret for authentication (REQUIRED - No default in production)
# Generate a secure key: openssl rand -base64 32
JWT_SECRET=

# Cookie Secret for secure cookies (REQUIRED - No default in production)  
# Generate a secure key: openssl rand -base64 32
COOKIE_SECRET=

# JWT Token expiration
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Session configuration
SESSION_COOKIE_NAME=ventry-session
SESSION_COOKIE_MAX_AGE=86400000 # 24 hours in milliseconds

# ====================================
# API CONFIGURATION
# ====================================

# API URL for frontend (uses Next.js proxy to avoid CORS)
NEXT_PUBLIC_API_URL=/api/trpc

# Backend API Port
API_PORT=6060

# Frontend Port
NEXT_PORT=6061

# ====================================
# SENTRY ERROR TRACKING (Optional)
# ====================================

# Get these from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# ====================================
# AI CONFIGURATION (Phase 3)
# ====================================

# OpenAI API Configuration
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# Anthropic API Configuration (Alternative)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-opus-20240229
ANTHROPIC_MAX_TOKENS=4096

# ====================================
# EMAIL CONFIGURATION (Future)
# ====================================

# SMTP Configuration for notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@ventry.com

# ====================================
# STORAGE CONFIGURATION (Future)
# ====================================

# S3-compatible storage for file uploads
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=ventry-uploads

# Or use Supabase Storage (if using Supabase)
# Storage is automatically configured with Supabase

# ====================================
# DEVELOPMENT CONFIGURATION
# ====================================

# Node environment
NODE_ENV=development

# Enable debug logging
DEBUG=ventry:*

# Prisma logging
# Options: query, info, warn, error
PRISMA_LOG_LEVEL=warn

# ====================================
# REDIS CONFIGURATION (Future)
# ====================================

# Redis for caching and sessions
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ====================================
# MONITORING & ANALYTICS (Future)
# ====================================

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Posthog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ====================================
# FEATURE FLAGS
# ====================================

# Enable/disable features
ENABLE_AI_AGENTS=false
ENABLE_REALTIME_UPDATES=false
ENABLE_ADVANCED_ANALYTICS=false

# ====================================
# SECURITY
# ====================================

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:6061,http://localhost:6060

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ====================================
# NOTES
# ====================================

# 1. Never commit .env files to version control
# 2. Use different values for production
# 3. Keep service keys secure and never expose them to the client
# 4. Rotate secrets regularly
# 5. Use environment-specific files:
#    - .env.local (local development)
#    - .env.development (development server)
#    - .env.staging (staging server)
#    - .env.production (production server)