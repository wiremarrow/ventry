# Supabase Configuration
# Copy this file to .env.local or update your existing .env file

# Supabase Database URL (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
SUPABASE_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Direct connection for migrations (bypasses connection pooler)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Supabase API Keys
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# Optional: Supabase Storage
SUPABASE_STORAGE_BUCKET="ventry-assets"

# Migration Configuration
# Keep existing auth system during migration
USE_SUPABASE_AUTH="false"
MIGRATION_MODE="dual" # dual | supabase-only | legacy-only