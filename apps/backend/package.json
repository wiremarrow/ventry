{
  "name": "@ventry/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "start:prod": "NODE_ENV=production tsx src/server.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage --exclude='**/*.integration.spec.ts' --exclude='**/test-helpers/**'",
    "test:debug": "vitest --inspect-brk",
    "db:generate": "prisma generate --schema=../../packages/database/prisma/schema.prisma",
    "db:push": "prisma db push --schema=../../packages/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=../../packages/database/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=../../packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/compress": "^8.1.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.1.0",
    "@prisma/client": "^6.11.1",
    "@trpc/client": "^11.4.3",
    "@trpc/server": "11.4.3",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@ventry/database": "workspace:*",
    "@ventry/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^17.1.0",
    "fastify": "^5.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "superjson": "^2.2.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.0.0",
    "prisma": "^6.11.1",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.1",
    "typescript": "^5.1.3",
    "vitest": "^3.2.4"
  }
}
